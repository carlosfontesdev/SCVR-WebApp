<div class="text-center mb-5">
    <h1 class="display-4">Gerir Produtos</h1>
    <hr class="border-vermelho" />
</div>
    <form asp-controller="GerirProduto" asp-action="Index" method="post">
        <label for="nome">Filtrar Por Nome:</label>
        <select name="nome" id="nome" class="form-select">
            <option value="" selected disabled hidden>Selecione Nome</option>
            <option value="Camisola Casa SCVR">Camisola Casa SCVR</option>
            <option value="Camisola Fora SCVR">Camisola Fora SCVR</option>
            <option value="Cachecol Oficial">Cachecol Oficial</option>
        </select>
        <label for="tamanho">Filtrar Por Tamanho:</label>
        <select name="tamanho" id="tamanho" class="form-select">
            <option value="" selected disabled hidden>Selecione um Tamanho</option>
            <option value="S">S</option>
            <option value="M">M</option>
            <option value="L">L</option>
            <option value="XL">XL</option>
            <option value="Único">Único</option>
        </select>

        <button type="submit" name="clicado" value="1" class="btn-buy">Filtrar</button>
        <br />
    </form>
    <table class="table table-striped table-hover mt-3">
        <thead class="table-dark">
            <tr>
                <th>Nome</th>
                <th>Descrição</th>
                <th>Tipo</th>
                <th>Tamanho</th>
                <th>Preço </th>
                <th>Stock</th>
            </tr>
        </thead>
        <tbody>


            @foreach (var item in ViewBag.Produto)
            {
                <tr>
                    <td>@item.Nome</td>
                    <td>@item.Descricao</td>
                    <td>@item.Tipo</td>
                    <td>@item.Tamanho</td>
                    <td>@item.Preco €</td>
                    <td>@item.Stock</td>
                </tr>
            }

        </tbody>
    </table>
    <form asp-controller="AlterarPrecoCamisolaCasa" asp-action="Index" method="post">
        <button type="submit" name="AlterarPrecoCamisolaCasa" value="1">Alterar Preço Camisola Casa</button>
    </form>
    <br />
    <form asp-controller="AlterarPrecoCamisolaFora" asp-action="Index" method="post">
        <button type="submit" name="AlterarPrecoCamisolaFora" value="1">Alterar Preço Camisola Fora</button>
    </form>
    <br />
    <form asp-controller="AlterarPrecoCachecol" asp-action="Index" method="post">
        <button type="submit" name="AlterarPrecoCachecol" value="1">Alterar Preço Cachecol</button>
    </form>
    <br />
    <form asp-controller="AdicionarProdutos" asp-action="Index" method="post">
        <button type="submit" name="AdicionarProdutos" value="1">Adicionar Produtos</button>
    </form>
    
