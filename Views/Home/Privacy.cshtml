

@{
    ViewData["Title"] = "Classificação";
}

<div class="container mt-4">
    <h1 class="text-center mb-4">@ViewData["Title"]</h1>
    <h2 class="text-secondary">Campeonato de Portugal - Série B</h2>

    <table class="table table-striped table-hover mt-3">
        <thead class="table-dark">
            <tr>
                <th>Posição</th>
                <th>Equipa</th>
                <th class="text-center">Jogos</th>
                <th class="text-center">Pts</th>
            </tr>
        </thead>
        <tbody>
            
            
                @foreach (var item in ViewBag.classificacao)
                {
                    <tr>
                        <td><strong>@item.Posicao º</strong></td>
                        <td>@item.Nome</td>
                        <td class="text-center">@item.Jogos</td>
                        <td class="text-center"><strong>@item.Pts</strong></td>
                    </tr>
                }
            
        </tbody>
    </table>
</div>