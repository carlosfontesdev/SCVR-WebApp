<div class="text-center mb-5">
    <h1 class="display-4">Gerir Utilizadores</h1>
    <hr class="border-vermelho" />
</div>

<table class="table table-striped table-hover mt-3">
    <thead class="table-dark">
        <tr>
            <th>Username</th>
            <th>Email</th>
            <th>Telemovel</th>
            <th>Sócio</th>
            <th>Numero de Sócio</th>
            <th>Eliminar Utilizador</th>
        </tr>
    </thead>
    <tbody>


        @foreach (var item in ViewBag.Utilizadores)
        {
            <tr>
                <td>@item.UserName</td>
                <td>@item.Email</td>
                <td>@item.PhoneNumber</td>
                <td>@item.IsSocio</td>
                <td>@item.NumeroSocio</td>
                <td><a asp-controller="GerirUtilizadores" asp-action="EliminarUtilizador" asp-route-id="@item.Id">Eliminar Utilizador</a></td>
            </tr>
        }

    </tbody>
</table>